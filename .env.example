# Токен вашего Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID вашего Telegram канала (например, @my_channel_username или числовой ID вроде -100123456789)
TELEGRAM_CHANNEL_ID=@your_channel_username

# API ключ от Google AI Studio (Gemini API)
GEMINI_API_KEY=your_gemini_api_key_here

# Используемая модель ИИ (по умолчанию gemini-3.5-flash)
GEMINI_MODEL=gemini-3.5-flash

# Путь к базе данных (необязательно)
# DATABASE_PATH=bot_database.db
